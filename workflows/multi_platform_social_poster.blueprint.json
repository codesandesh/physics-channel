                      },
                      "mapper": {
                        "url": "https://graph.facebook.com/v19.0/YOUR_IG_USER_ID/media_publish",
                        "serializeUrl": true,
                        "method": "post",
                        "headers": [],
                        "queryParameters": {
                          "array": [
                            {
                              "key": "creation_id",
                              "value": "{{9.data.id}}"
                            },
                            {
                              "key": "access_token",
                              "value": "YOUR_IG_ACCESS_TOKEN"
                            }
                          ]
                        },
                        "bodyType": "raw",
                        "contentType": "application/x-www-form-urlencoded",
                        "body": "",
                        "parseResponse": true,
                        "timeout": 30,
                        "followRedirect": true,
                        "gzip": true,
                        "rejectUnauthorized": true
                      },
                      "metadata": {
                        "designer": {
                          "x": 850,
                          "y": 200
                        },
                        "parameters": [
                          {
                            "name": "handleErrors",
                            "type": "boolean",
                            "label": "Evaluate all states as errors (except for 2xx and 3xx)"
