                      ]
                    ]
                  },
                  "flow": [
                    {
                      "id": 9,
                      "module": "http:ActionSendData",
                      "version": 3,
                      "parameters": {
                        "handleErrors": false,
                        "useNewZLibDecompress": true
                      },
                      "mapper": {
                        "url": "https://graph.facebook.com/v19.0/YOUR_IG_USER_ID/media",
                        "serializeUrl": true,
                        "method": "post",
                        "headers": [],
                        "queryParameters": {
                          "array": [
                            {
                              "key": "video_url",
                              "value": "{{1.media_url}}"
                            },
                            {
                              "key": "caption",
                              "value": "{{1.instagram_caption}}"
                            },
                            {
                              "key": "media_type",
                              "value": "REELS"
                            },
                            {
                              "key": "share_to_feed",
                              "value": "true"
                            },
                            {
                              "key": "access_token",
                              "value": "YOUR_IG_ACCESS_TOKEN"
                            }
                          ]
                        },
                        "bodyType": "raw",
                        "contentType": "application/x-www-form-urlencoded",
                        "body": "",
                        "parseResponse": true,
                        "timeout": 30,
                        "followRedirect": true,
                        "gzip": true,
                        "rejectUnauthorized": true
                      },
                      "metadata": {
                        "designer": {
                          "x": 500,
                          "y": 200
                        },
                        "parameters": [
                          {
                            "name": "handleErrors",
