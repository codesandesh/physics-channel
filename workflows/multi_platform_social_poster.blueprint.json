                          {
                            "name": "useNewZLibDecompress",
                            "type": "boolean",
                            "label": "Use new ZLib decompression"
                          }
                        ]
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "label": "TikTok",
          "flow": [
            {
              "id": 11,
              "module": "builtin:BasicRouter",
              "version": 1,
              "parameters": {},
              "mapper": {},
              "metadata": {
                "designer": {
                  "x": 150,
                  "y": 350
                }
              },
              "routes": [
                {
                  "label": "TikTok Video",
                  "filter": {
                    "name": "Is Video",
                    "conditions": [
                      [
                        {
                          "a": "{{1.post_type}}",
                          "b": "video",
                          "o": "text:equal"
                        }
                      ]
                    ]
                  },
                  "flow": [
                    {
                      "id": 12,
                      "module": "http:ActionSendData",
                      "version": 3,
                      "parameters": {
                        "handleErrors": false,
                        "useNewZLibDecompress": true
                      },
                      "mapper": {
                        "url": "https://open.tiktokapis.com/v2/post/publish/video/init/",
                        "serializeUrl": false,
                        "method": "post",
                        "headers": [
                          {
                            "name": "Authorization",
                            "value": "Bearer YOUR_TIKTOK_ACCESS_TOKEN"
                          },
                          {
                            "name": "Content-Type",
                            "value": "application/json; charset=UTF-8"
                          }
                        ],
                        "queryParameters": {
                          "array": []
                        },
                        "bodyType": "raw",
                        "contentType": "application/json",
                        "body": "{\"post_info\":{\"title\":\"{{1.tiktok_caption}}\",\"privacy_level\":\"PUBLIC_TO_EVERYONE\",\"disable_duet\":false,\"disable_comment\":false,\"disable_stitch\":false,\"video_cover_timestamp_ms\":1000},\"source_info\":{\"source\":\"PULL_FROM_URL\",\"video_url\":\"{{1.media_url}}\"}}",
                        "parseResponse": true,
                        "timeout": 30,
                        "followRedirect": true,
                        "gzip": true,
                        "rejectUnauthorized": true
                      },
                      "metadata": {
                        "designer": {
                          "x": 500,
