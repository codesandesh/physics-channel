                            "value": "application/json; charset=UTF-8"
                          }
                        ],
                        "queryParameters": {
                          "array": []
                        },
                        "bodyType": "raw",
                        "contentType": "application/json",
                        "body": "{\"post_info\":{\"title\":\"{{1.tiktok_caption}}\",\"description\":\"{{1.tiktok_caption}}\",\"privacy_level\":\"PUBLIC_TO_EVERYONE\",\"disable_comment\":false},\"source_info\":{\"source\":\"PULL_FROM_URL\",\"photo_cover_index\":0,\"photo_images\":[\"{{1.media_url}}\"]},\"post_mode\":\"DIRECT_POST\",\"media_type\":\"PHOTO\"}",
                        "parseResponse": true,
                        "timeout": 30,
