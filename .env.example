# ════════════════════════════════════════════════════════════════
#  Physics Channel Pipeline  –  Complete Environment Variables
#  Copy this file to .env and fill in every value.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
# Public IP or domain of your server (no trailing slash)
SERVER_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# ── n8n ──────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_HOST=0.0.0.0
N8N_PORT=5678
# Full base URL for webhooks — must be publicly reachable
N8N_WEBHOOK_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN:5678

# Stage 2 webhook URL (constructed from base URL — do not change path)
# n8n will expose:  http://YOUR_IP:5678/webhook/stage2-manim
# Stage 3 webhook URL:
# n8n will expose:  http://YOUR_IP:5678/webhook/stage3-assemble

# ── Anthropic / Claude ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── ElevenLabs ───────────────────────────────────────────────────
ELEVENLABS_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ELEVENLABS_VOICE_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── HeyGen ───────────────────────────────────────────────────────
HEYGEN_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
HEYGEN_AVATAR_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── YouTube Data API v3 ───────────────────────────────────────────
# OAuth2 scopes required:
#   https://www.googleapis.com/auth/youtube.upload
#   https://www.googleapis.com/auth/youtube
# Create credentials at: https://console.cloud.google.com/
# Credential type: OAuth 2.0 Client ID (Web application)
# Authorized redirect URI for n8n: http://YOUR_SERVER_IP:5678/rest/oauth2-credential/callback
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_OAUTH_CLIENT_ID=XXXXXXXXXXXX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_OAUTH_CLIENT_SECRET=GOCSPX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Google Drive ─────────────────────────────────────────────────
# Folder ID from the Google Drive URL
# OAuth2 scopes required:
#   https://www.googleapis.com/auth/drive
#   https://www.googleapis.com/auth/drive.file
GOOGLE_DRIVE_FOLDER_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Google Apps Script ───────────────────────────────────────────
# The Web App URL deployed from your Apps Script project
# Apps Script will append ?action=manim_callback and ?action=publish_callback
APPS_SCRIPT_CALLBACK_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/exec

# ── Container-internal paths (match Dockerfiles — do not change) ──
MANIM_SCRIPTS_DIR=/manim/scripts
MANIM_RENDERS_DIR=/manim/renders
MANIM_COMBINED_DIR=/manim/combined
FFMPEG_INPUT_DIR=/ffmpeg/input
FFMPEG_OUTPUT_DIR=/ffmpeg/output
FFMPEG_UPLOADS_DIR=/ffmpeg/uploads
