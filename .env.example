# ════════════════════════════════════════════════════════════
#  Quantum Physics Channel Pipeline — Environment Variables
#  Copy to .env and fill in every value on the server.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
SERVER_BASE_URL=https://physics.scalebuild.ai
N8N_WEBHOOK_BASE_URL=https://physics.scalebuild.ai
N8N_EDITOR_BASE_URL=https://physics.scalebuild.ai

# ── n8n ──────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_USER_MANAGEMENT_ADMIN_EMAIL=
N8N_USER_MANAGEMENT_ADMIN_PASSWORD=
N8N_ENCRYPTION_KEY=
N8N_HOST=0.0.0.0
N8N_PORT=5679

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=

# ── AI APIs ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_API_KEY_APERTURE=
ELEVENLABS_VOICE_ID_APERTURE=

# ── Video Generation ─────────────────────────────────────────
WAVESPEED_API_KEY=
VASTAI_GPU1_URL=
VASTAI_GPU1_API_KEY=
VASTAI_VIDEO_URL=
VASTAI_VIDEO_API_KEY=
VASTAI_VIDEO_WORKER=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# ── YouTube ──────────────────────────────────────────────────
YOUTUBE_CHANNEL_ID=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Google Drive ─────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_ID_IMAGES=
GOOGLE_DRIVE_FOLDER_ID_VIDEOS=

# ── Google Sheets ─────────────────────────────────────────────
GOOGLE_SHEET_ID=
GOOGLE_SHEET_ID_IMAGE_POSTS=
GOOGLE_SHEET_TAB_CONTENT_MASTER=Content Master Table
GOOGLE_SHEET_TAB_VIDEO_QUEUE=Video Production Queue
GOOGLE_SHEET_TAB_IMAGE_TOPICS=Image Topics
GOOGLE_SHEET_TAB_IMAGE_QUEUE=Image Post Queue

# ── Google Apps Script ───────────────────────────────────────
APPS_SCRIPT_CALLBACK_URL=

# ── Tavily ───────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Facebook ─────────────────────────────────────────────────
FB_PAGE_ID=
FB_APP_ID=
FB_APP_SECRET=
FB_USER_ACCESS_TOKEN=
FB_PAGE_ACCESS_TOKEN=

# ── LinkedIn ─────────────────────────────────────────────────
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_ACCESS_TOKEN=

# ── Instagram / TikTok ───────────────────────────────────────
INSTAGRAM_BUSINESS_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_APP_AUDITED=false

# ── Ayrshare — ONE API key, per-channel profile IDs ──────────
AYRSHARE_API_KEY=
AYRSHARE_PHYSICS_IG_PROFILE_ID=
AYRSHARE_PHYSICS_TIKTOK_PROFILE_ID=
AYRSHARE_APERTURE_IG_PROFILE_ID=
AYRSHARE_APERTURE_TIKTOK_PROFILE_ID=
AYRSHARE_SHN_IG_PROFILE_ID=
AYRSHARE_SHN_TIKTOK_PROFILE_ID=
AYRSHARE_FITNESS_IG_PROFILE_ID=
AYRSHARE_FITNESS_TIKTOK_PROFILE_ID=

# ── Container paths (do not change) ──────────────────────────
MANIM_SCRIPTS_DIR=/manim/scripts
MANIM_RENDERS_DIR=/manim/renders
MANIM_COMBINED_DIR=/manim/combined
FFMPEG_INPUT_DIR=/ffmpeg/input
FFMPEG_OUTPUT_DIR=/ffmpeg/output
FFMPEG_UPLOADS_DIR=/ffmpeg/uploads
